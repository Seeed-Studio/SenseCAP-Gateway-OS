{
    "luci-app-lte": {
        "description": "Grant access to LTE configuration",
        "read": {
            "uci": [ "network", "hardware" ],
            "file": {
                "/etc/init.d/lte-serve": [ "exec" ],
                "/var/run/lte-info.json": [ "read" ]
            }
        },
        "write": {
            "uci": [ "network", "hardware" ],
            "file": {
                "/etc/init.d/lte-serve": [ "exec" ]
            }
        }
    }
}
